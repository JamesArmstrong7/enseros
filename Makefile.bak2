CC = gcc

CFLAGS = \
	-D_POSIX_C_SOURCE=200809L \
	-Wall \
	-Wextra \
	-Werror \
	-pedantic \
	-std=c11 \
	-Iinclude

LIB_SRC = \
	$(wildcard src/core/*.c) \
	$(wildcard src/causal_sequencer/*.c) \
	$(wildcard src/persistence_log/*.c) \
	$(wildcard src/lba/*.c) \
	$(wildcard src/iyunux/*.c) \
	$(wildcard src/pipo/*.c) \
	$(wildcard src/cromo/*.c) \
	$(wildcard src/teddy/*.c) \
	$(wildcard src/cnux/*.c)

TEST_SRC = \
	tests/main.c \
	tests/test_create.c \
	tests/test_parse.c \
	tests/test_view.c \
	tests/test_integrate.c

LOG_TEST_SRC = tests/test_log.c

SRC = \
	$(LIB_SRC) \
	$(TEST_SRC)

OBJ = \
	$(SRC:.c=.o)

LOG_TEST_OBJ = \
	$(LOG_TEST_SRC:.c=.o)

BIN = bin/test
LOG_TEST_BIN = bin/test_log

all: $(BIN) $(LOG_TEST_BIN)

$(BIN): $(OBJ)
	@mkdir -p bin
	$(CC) $(OBJ) -o $(BIN)

$(LOG_TEST_BIN): $(LOG_TEST_OBJ)
	@mkdir -p bin
	$(CC) $(LOG_TEST_OBJ) -o $(LOG_TEST_BIN)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

run: all
	./$(BIN)
	./$(LOG_TEST_BIN)

clean:
	find src tests -name "*.o" -delete
	rm -rf bin storage lba.jsonl lba

.PHONY: all run clean
